<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body data-user-role="admin">
    <%- include('../partials/header') %>
        <main id="main-content" role="main">
            <%- include('../partials/flash') %>
                <div class="flex-between mb-lg">
                    <h1>Manage Users</h1>
                    <a href="/admin/dashboard" class="btn btn-secondary btn-sm">&larr; Dashboard</a>
                </div>
                <!-- Role filter -->
                <form method="GET" action="/admin/users" class="mb-lg" aria-label="Filter users by role">
                    <fieldset
                        style="border:none; padding:0; display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                        <legend class="sr-only">Filter by role</legend>
                        <a href="/admin/users"
                            class="btn <%= filterRole === 'all' ? 'btn-primary' : 'btn-secondary' %> btn-sm">All</a>
                        <a href="/admin/users?role=seeker"
                            class="btn <%= filterRole === 'seeker' ? 'btn-primary' : 'btn-secondary' %> btn-sm">Seekers</a>
                        <a href="/admin/users?role=employer"
                            class="btn <%= filterRole === 'employer' ? 'btn-primary' : 'btn-secondary' %> btn-sm">Employers</a>
                        <a href="/admin/users?role=admin"
                            class="btn <%= filterRole === 'admin' ? 'btn-primary' : 'btn-secondary' %> btn-sm">Admins</a>
                    </fieldset>
                </form>
                <p class="mb-lg"><strong>
                        <%= users.length %>
                    </strong> user<%= users.length !==1 ? 's' : '' %> found</p>
                <table class="data-table" aria-label="User management table">
                    <thead>
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Name</th>
                            <th scope="col">Email</th>
                            <th scope="col">Role</th>
                            <th scope="col">Joined</th>
                            <th scope="col">Status</th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(function(u) { %>
                            <tr>
                                <td>
                                    <%= u.id %>
                                </td>
                                <td>
                                    <%= u.name %>
                                </td>
                                <td>
                                    <%= u.email %>
                                </td>
                                <td>
                                    <%= u.role %>
                                </td>
                                <td>
                                    <%= new Date(u.created_at).toLocaleDateString() %>
                                </td>
                                <td>
                                    <span class="badge <%= u.is_approved ? 'badge-active' : 'badge-suspended' %>">
                                        <%= u.is_approved ? 'Active' : 'Suspended' %>
                                    </span>
                                </td>
                                <td>
                                    <form method="POST" action="/admin/users/<%= u.id %>/toggle"
                                        style="display:inline;">
                                        <button type="submit"
                                            class="btn btn-sm <%= u.is_approved ? 'btn-danger' : 'btn-primary' %>"
                                            aria-label="<%= u.is_approved ? 'Suspend' : 'Activate' %> <%= u.name %>">
                                            <%= u.is_approved ? 'Suspend' : 'Activate' %>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
        </main>
        <%- include('../partials/footer') %>
            <script src="/js/accessibility.js"></script>
            <script src="/js/voice-nav.js"></script>
</body>

</html>